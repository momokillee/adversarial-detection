def compute_mahalanobis_scores(paths, resnet, extractor, class_means, precision, maha_mean, maha_std, device):
    scores = []
    with torch.no_grad():
        for path in paths:
            img = load_image_tensor(path, IMAGE_SIZE, device).to(device)
            _ = resnet(img)
            feat = extractor.get().squeeze(0)
            raw = float(mahalanobis_score(feat, class_means, precision))
            z = (raw - maha_mean) / maha_std
            scores.append(-z)
    return np.array(scores, dtype=np.float64)
